# Supabase project URL (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service_role key (Project Settings -> API -> service_role)
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# bcrypt hash of your access password (generate with: npm run hash-password)
APP_PASSWORD_HASH=

# 32+ character random string used to sign the session cookie
# Generate with: npm run gen-secret
COOKIE_SECRET=
